<Window x:Class="AlMunadi.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Al Munadi" Height="760" Width="820" MinHeight="600" MinWidth="720"
        Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource TextPrimaryBrush}">
    <Grid Margin="22">
        <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <TabControl Background="{StaticResource CardBrush}" BorderBrush="{StaticResource DividerBrush}">
            <TabItem x:Name="MosqueTab">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="20">
                    <TextBlock x:Name="SearchHintLabel" />
                    <DockPanel Margin="0,8,0,0"><Button x:Name="SearchButton" DockPanel.Dock="Right" Margin="8,0,0,0" Click="SearchMosques" /><TextBox x:Name="SearchQuery" Padding="8" /></DockPanel>
                    <TextBlock x:Name="SearchStatus" Margin="0,8,0,0" Foreground="{StaticResource SaffronBrush}" />
                    <ListBox x:Name="SearchResults" Height="150" Margin="0,8,0,16" MouseDoubleClick="SelectSearchResult" DisplayMemberPath="DisplayName" />
                    <TextBlock x:Name="MosqueUrlLabel" />
                    <TextBox x:Name="MosqueUrl" Margin="0,8,0,0" Padding="8" />
                    <TextBlock x:Name="UrlStatus" Margin="0,8,0,0" Foreground="{StaticResource SaffronBrush}" />
                    <TextBlock x:Name="SavedMosquesLabel" Margin="0,18,0,0" />
                    <ListBox x:Name="SavedMosques" Height="120" Margin="0,8,0,8" DisplayMemberPath="Name" MouseDoubleClick="SelectSavedMosque" />
                    <StackPanel Orientation="Horizontal"><Button x:Name="AddMosqueButton" Click="AddCurrentMosque" /><Button x:Name="RemoveMosqueButton" Margin="8,0,0,0" Click="RemoveSavedMosque" /></StackPanel>
                </StackPanel></ScrollViewer>
            </TabItem>
            <TabItem x:Name="DisplayTab">
                <StackPanel Margin="20">
                    <TextBlock x:Name="DisplayModeLabel" /><ComboBox x:Name="DisplayMode" Margin="0,8,0,16" />
                    <TextBlock x:Name="CountdownFormatLabel" /><ComboBox x:Name="CountdownFormat" Margin="0,8,0,16" />
                    <TextBlock x:Name="LanguageLabel" /><ComboBox x:Name="LanguageSelector" Margin="0,8,0,0" SelectionChanged="LanguageChanged" />
                </StackPanel>
            </TabItem>
            <TabItem x:Name="NotificationsTab">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="20">
                    <CheckBox x:Name="NotificationsEnabled" Margin="0,0,0,12" />
                    <CheckBox x:Name="DndBypass" Margin="0,0,0,8" />
                    <TextBlock x:Name="DndNote" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="PerPrayerLabel" Margin="0,20,0,8" FontWeight="SemiBold" />
                    <StackPanel x:Name="PrayerNotificationsPanel" />
                </StackPanel></ScrollViewer>
            </TabItem>
            <TabItem x:Name="AdhanTab">
                <StackPanel Margin="20">
                    <CheckBox x:Name="AdhanEnabled" Margin="0,0,0,16" />
                    <TextBlock x:Name="AdhanPathLabel" />
                    <DockPanel Margin="0,8,0,12"><Button x:Name="BrowseButton" DockPanel.Dock="Right" Margin="8,0,0,0" Click="BrowseAdhan" /><TextBox x:Name="AdhanPath" Padding="8" /></DockPanel>
                    <StackPanel Orientation="Horizontal"><Button x:Name="TestAdhanButton" Click="TestAdhan" /><Button x:Name="StopAdhanButton" Margin="8,0,0,0" Click="StopAdhan" /></StackPanel>
                    <TextBlock x:Name="AdhanStatus" Margin="0,10,0,0" Foreground="{StaticResource SaffronBrush}" />
                </StackPanel>
            </TabItem>
            <TabItem x:Name="OffsetsTab">
                <StackPanel Margin="20">
                    <TextBlock x:Name="OffsetsHint" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    <StackPanel x:Name="OffsetsPanel" Margin="0,16,0,12" />
                    <Button x:Name="ResetOffsetsButton" HorizontalAlignment="Left" Click="ResetOffsets" />
                </StackPanel>
            </TabItem>
            <TabItem x:Name="AppTab">
                <StackPanel Margin="20">
                    <CheckBox x:Name="LaunchAtLogin" Margin="0,0,0,18" />
                    <TextBlock x:Name="VersionText" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal"><Button x:Name="OpenReleasesButton" Click="OpenReleases" /><Button x:Name="TestNotificationButton" Margin="8,0,0,0" Click="TestNotification" /></StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>
        <Button x:Name="SaveButton" Grid.Row="1" HorizontalAlignment="Right" Margin="0,16,0,0" Click="Save" />
    </Grid>
</Window>
