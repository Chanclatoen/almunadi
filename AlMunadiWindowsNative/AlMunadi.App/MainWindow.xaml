<Window x:Class="AlMunadi.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Al Munadi" Height="560" Width="390"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource TextPrimaryBrush}">
    <Border BorderBrush="{StaticResource DividerBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel>
                <TextBlock Text="AL MUNADI" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                <TextBlock x:Name="MosqueName" Margin="0,5,0,0" FontSize="20" FontWeight="SemiBold" />
                <TextBlock x:Name="MetaText" Margin="0,3,0,0" Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBlock x:Name="StatusText" Margin="0,4,0,0" Foreground="{StaticResource SaffronBrush}" />
            </StackPanel>
            <Grid x:Name="WelcomePanel" Grid.Row="1" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="WelcomeTitle" FontSize="22" FontWeight="SemiBold" TextAlignment="Center" />
                    <TextBlock x:Name="WelcomeBody" Margin="20,12"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" />
                    <Button x:Name="FindMosqueButton" Click="OpenSettings" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
            <StackPanel x:Name="SchedulePanel" Grid.Row="1" Margin="0,18,0,0" Visibility="Collapsed">
                <Border Background="#1B2E26" CornerRadius="8" Padding="14" BorderBrush="{StaticResource AccentBrush}" BorderThickness="4,0,0,0">
                    <StackPanel>
                        <TextBlock x:Name="NextPrayerLabel" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" />
                        <TextBlock x:Name="NextPrayerText" Margin="0,5,0,0" FontSize="25" FontWeight="SemiBold" />
                        <TextBlock x:Name="NextIqamaText" Margin="0,4,0,0" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>
                <ItemsControl x:Name="PrayerRows" Margin="0,12,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,7">
                                <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}" Foreground="{Binding Foreground}" Opacity="{Binding Opacity}" />
                                <TextBlock Grid.Column="1" Text="{Binding Time}" FontFamily="Consolas" Foreground="{Binding Foreground}" Opacity="{Binding Opacity}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            <Grid Grid.Row="2" Margin="0,14,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <Button x:Name="RefreshButton" Click="Refresh" />
                <Button x:Name="SettingsButton" Grid.Column="1" Margin="8,0,0,0" Click="OpenSettings" />
            </Grid>
        </Grid>
    </Border>
</Window>
