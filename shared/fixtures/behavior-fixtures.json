{
  "description": "Cross-platform behavior fixtures. Python (core/al_munadi_core.py via AlMunadiWindows/test_al_munadi.py) and GNOME JS (tests/test_utils.js) both assert against this file so the platforms cannot drift apart. Swift/macOS should adopt the same cases (see shared/product-behavior.md).",
  "countdown": {
    "compact": [
      { "remaining_minutes": 150, "expected": "-2h30m" },
      { "remaining_minutes": 60, "expected": "-1h00m" },
      { "remaining_minutes": 15, "expected": "-15m" },
      { "remaining_minutes": 1, "expected": "-1m" },
      { "remaining_minutes": 0, "expected": "now" }
    ],
    "full": [
      { "remaining_minutes": 150, "expected": "-2h 30m" },
      { "remaining_minutes": 60, "expected": "-1h 00m" },
      { "remaining_minutes": 15, "expected": "-15m" },
      { "remaining_minutes": 1, "expected": "-1m" },
      { "remaining_minutes": 0, "expected": "now" }
    ]
  },
  "elapsed_since": {
    "compact": [
      { "elapsed_minutes": 75, "expected": "+1h15m" },
      { "elapsed_minutes": 60, "expected": "+1h00m" },
      { "elapsed_minutes": 12, "expected": "+12m" },
      { "elapsed_minutes": 0, "expected": "now" }
    ],
    "full": [
      { "elapsed_minutes": 75, "expected": "+1h 15m" },
      { "elapsed_minutes": 12, "expected": "+12m" }
    ]
  },
  "tray_title": [
