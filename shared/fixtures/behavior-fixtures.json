    { "mode": "time", "name": "Dhuhr", "time": "13:41", "countdown": "-2h18m", "remaining_minutes": 138, "expected": "Dhuhr  13:41" },
    { "mode": "name", "name": "Dhuhr", "time": "13:41", "countdown": "-2h18m", "remaining_minutes": 138, "expected": "Dhuhr" },
    { "mode": "compact", "name": "Dhuhr", "time": "13:41", "countdown": "-2h18m", "remaining_minutes": 138, "expected": "Dhuhr  -2h18m" },
    { "mode": "icon", "name": "Dhuhr", "time": "13:41", "countdown": "-2h18m", "remaining_minutes": 138, "expected": "Dhuhr" }
